# Frontend (Vite) — aman untuk dipublikasikan
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=/api/v1
VITE_TURNSTILE_SITE_KEY=

# Backend API — JANGAN commit ke git, JANGAN expose ke frontend
NODE_ENV=development
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=3001

# CORS — comma-separated untuk multiple origins (production)
CORS_ORIGIN=http://localhost:5173

# Redis (Upstash / Railway) — opsional di dev, disarankan di staging/prod
REDIS_URL=

# Cache TTL (detik)
CACHE_TTL_CAMPAIGNS=60
CACHE_TTL_CAMPAIGN_DETAIL=30
CACHE_TTL_ROLE=300

# Supabase query timeout (ms)
SUPABASE_TIMEOUT_MS=10000

# Donation abuse limits
DONATION_MAX_PER_USER_DAY=20
DONATION_MAX_PER_CAMPAIGN_HOUR=5
DONATION_DUPLICATE_WINDOW_SEC=30

# Monitoring (production)
SENTRY_DSN=
LOG_LEVEL=info

# Cloudflare Turnstile (production) — backend secret
TURNSTILE_SECRET_KEY=

# --- Environment separation ---
# development: local machine (.env.development)
# staging:     Railway staging service + Supabase staging project
# production:  Railway prod service + Supabase prod project
